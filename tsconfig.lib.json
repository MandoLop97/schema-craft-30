{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist",
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "types": ["vite/client"]
  },
  "include": [
    "src/index.ts",
    "src/vite-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}